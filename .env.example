# Mistral AI (Required)
LUMINAE_MISTRAL_API_KEY=your_mistral_api_key_here
LUMINAE_MISTRAL_BUDGET_USD=15.00
LUMINAE_MAX_REQUEST_USD=0.50
LUMINAE_CIRCUIT_BREAKER_THRESHOLD=2.00

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
LUMINAE_SUPABASE_URL=https://your-project.supabase.co
LUMINAE_SUPABASE_ANON_KEY=your_anon_key
LUMINAE_SUPABASE_SERVICE_KEY=your_service_role_key

# Redis/Upstash (Required)
LUMINAE_UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
LUMINAE_UPSTASH_REDIS_REST_TOKEN=your_token

# Render (Backend)
LUMINAE_API_URL=https://luminae-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Demo mode samples
LUMINAE_DEMO_MODE=false
